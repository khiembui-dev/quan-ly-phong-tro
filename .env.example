# ===== SmartRent — environment variables =====
# Copy to `.env` and adjust for local dev.

# --- Profiles ---
SPRING_PROFILES_ACTIVE=dev

# --- Database (Postgres prod / dev with docker-compose) ---
DB_URL=jdbc:postgresql://localhost:5432/glassliving
DB_USERNAME=glass
DB_PASSWORD=glass_dev_pwd

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Mail (MailHog dev) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@smartrent.vn

# --- MinIO / S3 ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=glass_minio
S3_SECRET_KEY=glass_minio_dev_pwd
S3_REGION=ap-southeast-1
S3_BUCKET_PUBLIC=glass-public
S3_BUCKET_PRIVATE=glass-private

# --- JWT ---
JWT_SECRET=please-change-this-to-a-256-bit-random-string-for-production-glassliving-2026
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# --- Encryption (Jasypt) for CCCD column ---
JASYPT_PASSWORD=change-me-to-a-strong-passphrase

# --- OAuth Google (customer only) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Anthropic Claude (mock now, real later) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6

# --- Payment gateways ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:8080/api/v1/payments/vnpay/callback
VNPAY_IPN_URL=http://localhost:8080/api/v1/payments/vnpay/ipn
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# --- App ---
APP_BASE_URL=http://localhost:8080
APP_PORT=8080
